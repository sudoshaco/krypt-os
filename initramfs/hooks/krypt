#!/usr/bin/ash
# /etc/initcpio/hooks/krypt — Krypt OS mkinitcpio Runtime-Hook
#
# Sucht den Auth-Stick (64 Byte Key ab Offset 512) und öffnet LUKS2.
# Wenn kein Stick gefunden: läuft bis Erfolg (kein Passwort-Fallback by default).
#
# Kernel-Cmdline-Parameter:
#   krypt_luks_uuid=<UUID>    UUID des LUKS2-Devices (Pflicht)
#   krypt_luks_name=<name>    dm-crypt Name (default: krypt-root)
#   krypt_timeout=<sek>       Sekunden bis Fallback auf encrypt-Hook (0=nie, default=0)
#                             Für QEMU-Tests: krypt_timeout=15
#
# Stick-Format (via `krypt-stick setup`):
#   64 Byte Schlüsselmaterial ab Byte-Offset 512 (Sektor 1, hinter MBR)
#   Kein Filesystem nötig — Raw-Read via dd.

run_hook() {
    local luks_uuid=""
    local luks_name="krypt-root"
    local key_offset=512
    local key_size=64
    local krypt_timeout=0   # 0 = kein Timeout (Produktions-Default)

    # ─────────────────────────────────────────────────────────────────────────
    # Kernel-Cmdline parsen
    # ─────────────────────────────────────────────────────────────────────────
    for param in $(cat /proc/cmdline); do
        case "$param" in
            krypt_luks_uuid=*) luks_uuid="${param#krypt_luks_uuid=}" ;;
            krypt_luks_name=*) luks_name="${param#krypt_luks_name=}" ;;
            krypt_timeout=*)   krypt_timeout="${param#krypt_timeout=}" ;;
        esac
    done

    if [ -z "$luks_uuid" ]; then
        echo ""
        echo "  krypt: FEHLER — krypt_luks_uuid nicht in Kernel-Cmdline."
        echo "  Füge 'krypt_luks_uuid=<UUID>' zum Bootloader hinzu."
        echo ""
        launch_interactive_shell
        return 1
    fi

    local luks_dev="/dev/disk/by-uuid/$luks_uuid"

    # ─────────────────────────────────────────────────────────────────────────
    # udev: Block-Devices scannen + warten
    # ─────────────────────────────────────────────────────────────────────────
    udevadm trigger --action=add --subsystem-match=block 2>/dev/null
    udevadm settle --timeout=4 2>/dev/null

    # ─────────────────────────────────────────────────────────────────────────
    # Auth-Stick suchen und LUKS öffnen
    # Läuft bis Erfolg — oder bis krypt_timeout Sekunden abgelaufen (Fallback)
    # ─────────────────────────────────────────────────────────────────────────
    local banner_shown=0
    local elapsed=0

    while true; do
        if _krypt_try_open "$luks_dev" "$luks_name" "$key_offset" "$key_size"; then
            echo ""
            echo "  krypt: Authentifizierung erfolgreich."
            echo "  krypt: /dev/mapper/$luks_name bereit."
            echo ""
            return 0
        fi

        # Kein Stick oder falscher Schlüssel — Banner zeigen
        if [ "$banner_shown" -eq 0 ]; then
            _krypt_banner "$krypt_timeout"
            banner_shown=1
        fi

        # Timeout-Prüfung (krypt_timeout=0 → unendlich)
        if [ "$krypt_timeout" -gt 0 ] && [ "$elapsed" -ge "$krypt_timeout" ]; then
            echo ""
            echo "  krypt: Timeout nach ${krypt_timeout}s — Fallback auf encrypt-Hook."
            echo "  krypt: LUKS-Passphrase-Eingabe folgt."
            echo ""
            return 1   # encrypt-Hook öffnet LUKS via cryptdevice= + Passphrase-Prompt
        fi

        elapsed=$((elapsed + 1))
        sleep 1
        udevadm trigger --action=add --subsystem-match=block 2>/dev/null
        udevadm settle --timeout=2 2>/dev/null
    done
}

# ─────────────────────────────────────────────────────────────────────────────
# Versucht alle USB-Stick-Kandidaten — gibt 0 zurück bei Erfolg.
# ─────────────────────────────────────────────────────────────────────────────
_krypt_try_open() {
    local luks_dev="$1"
    local luks_name="$2"
    local key_offset="$3"
    local key_size="$4"

    # LUKS-Device muss als Block-Device vorhanden sein
    [ -b "$luks_dev" ] || return 1

    # dm-device bereits offen? Fertig.
    [ -b "/dev/mapper/$luks_name" ] && return 0

    # Alle USB-Block-Devices durchprobieren (keine Partitionen)
    for dev in /dev/disk/by-id/usb-*; do
        [ -b "$dev" ] || continue
        case "$dev" in *-part[0-9]*) continue ;; esac

        # 64 Byte ab Offset 512 lesen → direkt an cryptsetup pipen
        if dd if="$dev" bs=1 skip="$key_offset" count="$key_size" 2>/dev/null \
           | cryptsetup open \
               --type=luks2 \
               --key-file=- \
               --keyfile-size="$key_size" \
               "$luks_dev" "$luks_name" 2>/dev/null; then
            return 0
        fi
    done

    return 1
}

# ─────────────────────────────────────────────────────────────────────────────
# ASCII-Banner — erscheint beim Warten auf Auth-Stick
# ─────────────────────────────────────────────────────────────────────────────
_krypt_banner() {
    local timeout="$1"
    echo ""
    echo "  ██╗  ██╗██████╗ ██╗   ██╗██████╗ ████████╗"
    echo "  ██║ ██╔╝██╔══██╗╚██╗ ██╔╝██╔══██╗╚══██╔══╝"
    echo "  █████╔╝ ██████╔╝ ╚████╔╝ ██████╔╝   ██║   "
    echo "  ██╔═██╗ ██╔══██╗  ╚██╔╝  ██╔═══╝    ██║   "
    echo "  ██║  ██╗██║  ██║   ██║   ██║         ██║   "
    echo "  ╚═╝  ╚═╝╚═╝  ╚═╝   ╚═╝   ╚═╝         ╚═╝  "
    echo ""
    echo "  Authentication required."
    echo "  Insert your Krypt stick to continue."
    if [ "$timeout" -gt 0 ]; then
        echo "  (Fallback auf Passphrase nach ${timeout}s)"
    fi
    echo ""
}
